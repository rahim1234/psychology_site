# Copy this file to .env and fill in real values. Never commit the real .env file.

# --- Core ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# --- Rate limiting cache (Redis) ---
# Required in production so rate limits are shared across all gunicorn
# workers instead of counted separately per worker (see the CACHES comment
# in config/settings.py for why). Leave empty in local development to fall
# back to an in-process cache.
REDIS_URL=
# Example for production: REDIS_URL=redis://127.0.0.1:6379/1

# --- SMS (used to send the signup / login / password-reset verification code) ---
# This is the PRIMARY verification channel for this project — registration,
# login, and forgot-password all depend on it. In production you MUST set
# SMS_BACKEND to a real provider class or no verification code will ever be
# sent (it silently falls back to a placeholder backend that just logs an
# error). See accounts/sms_backends.py for the available backend classes.
#
# For local development you can leave SMS_BACKEND unset: codes are printed
# to the console/log instead of actually being texted.
#
# sms.ir example:
SMS_BACKEND=accounts.sms_backends.SmsIrSMSBackend
SMS_API_URL=https://api.sms.ir/v1/send/bulk
SMS_API_KEY=your-sms.ir-panel-api-key
SMS_SENDER_NUMBER=your-sms.ir-line-number
# Kavenegar example (use this SMS_BACKEND instead, and fill in the same
# SMS_API_KEY / SMS_SENDER_NUMBER with your Kavenegar credentials):
# SMS_BACKEND=accounts.sms_backends.KavenegarSMSBackend

# --- Phone verification behaviour ---
PHONE_VERIFICATION_TTL_MINUTES=10
PHONE_VERIFICATION_MAX_ATTEMPTS=5
PHONE_VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# --- Email (optional — NOT used for verification anymore; kept only for
# possible future use such as admin notifications). Safe to leave unset. ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-smtp-username
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@your-domain.ir

# --- Production hardening (leave unset to use safe defaults based on DEBUG) ---
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
