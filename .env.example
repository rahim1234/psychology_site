# Copy this file to .env and fill in real values. Never commit the real .env file.

# --- Core ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# --- Email (used to send the signup verification code) ---
# For local development you can leave EMAIL_BACKEND unset: codes will be
# printed to the console instead of actually being emailed.
# For production, use your real SMTP provider, e.g. Gmail, Mailgun, SendGrid, Zoho, etc.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-smtp-username
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@your-domain.ir

# --- Email verification behaviour ---
EMAIL_VERIFICATION_TTL_MINUTES=10
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# --- Production hardening (leave unset to use safe defaults based on DEBUG) ---
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
